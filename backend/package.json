    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "firebase-admin": "^13.7.0",
    "helmet": "^8.1.0",
    "jose": "^4.15.9",
    "openai": "^4.104.0",
    "pino": "^9.7.0",
    "pino-http": "^10.5.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/node": "^22.14.0",
    "@types/supertest": "^6.0.3",
    "@vitest/coverage-v8": "^3.2.4",
    "supertest": "^7.1.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
