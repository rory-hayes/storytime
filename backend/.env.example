NODE_ENV=development
PORT=8787
OPENAI_API_KEY=
OPENAI_RESPONSES_MODEL=gpt-4.1
OPENAI_MODERATION_MODEL=omni-moderation-latest
OPENAI_EMBEDDINGS_MODEL=text-embedding-3-small
OPENAI_REALTIME_MODEL=gpt-realtime
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
SESSION_SIGNING_SECRET=replace-with-a-long-random-secret
AUTH_TOKEN_SECRET=replace-with-a-second-long-random-secret
REALTIME_TICKET_TTL_SECONDS=90
SESSION_TOKEN_TTL_SECONDS=86400
SESSION_TOKEN_REFRESH_SECONDS=1800
REALTIME_RATE_LIMIT_WINDOW_MS=60000
REALTIME_RATE_LIMIT_MAX=20
GENERAL_RATE_LIMIT_WINDOW_MS=60000
GENERAL_RATE_LIMIT_MAX=120
MODERATION_RATE_LIMIT_MAX=60
DISCOVERY_RATE_LIMIT_MAX=40
STORY_RATE_LIMIT_MAX=12
EMBEDDINGS_RATE_LIMIT_MAX=40
ALLOWED_ORIGIN=*
ALLOWED_REGIONS=US,EU
DEFAULT_REGION=US
TRUST_PROXY=true
API_AUTH_REQUIRED=false
OPENAI_MAX_RETRIES=2
OPENAI_RETRY_BASE_MS=250
OPENAI_TIMEOUT_MS=20000
ENABLE_USAGE_METERING=true
ENABLE_STRUCTURED_ANALYTICS=true
APP_VERSION=0.1.0
